{
  "manifest_version": 3,
  "name": "United ✕ Starlink Odds",
  "version": "1.2.0",
  "description": "See which United flights get free Starlink WiFi, right in united.com search results. Data: unitedstarlinktracker.com",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://unitedstarlinktracker.com/*"],
  "background": {
    "service_worker": "bg.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.united.com/*", "https://united.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
